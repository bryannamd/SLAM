{
  "$comment": "tokens.json — 디자인 토큰의 canonical 원천. app/src/tokens.ts는 이 파일에서 생성된다. contrast_pairs는 validate가 WCAG AA(>=4.5:1, large>=3.0:1)로 실제 검사한다.",
  "color": {
    "primary": "#0F766E",
    "primaryLight": "#CCFBF1",
    "secondary": "#64748B",
    "background": "#FFFFFF",
    "surface": "#F8FAFC",
    "error": "#DC2626",
    "success": "#16A34A",
    "warning": "#D97706",
    "textPrimary": "#0F172A",
    "textSecondary": "#475569",
    "textDisabled": "#94A3B8",
    "divider": "#E2E8F0"
  },
  "typography": {
    "h1": { "size": 24, "weight": 700, "line": 32 },
    "h2": { "size": 20, "weight": 600, "line": 28 },
    "h3": { "size": 18, "weight": 600, "line": 24 },
    "body": { "size": 16, "weight": 400, "line": 24 },
    "caption": { "size": 12, "weight": 400, "line": 16 }
  },
  "spacing": { "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 32, "xxl": 48 },
  "radius": { "sm": 8, "md": 12, "lg": 16 },
  "contrast_pairs": [
    { "fg": "textPrimary", "bg": "background", "role": "normal" },
    { "fg": "textSecondary", "bg": "background", "role": "normal" },
    { "fg": "primary", "bg": "background", "role": "large" }
  ]
}
